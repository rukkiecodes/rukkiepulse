{
  "name": "rukkie-agent",
  "version": "0.1.0",
  "description": "RukkiePulse agent SDK — auto-instrument Node.js services and push telemetry to Jaeger",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/**/*",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prepublishOnly": "tsc"
  },
  "keywords": [
    "rukkiepulse",
    "observability",
    "opentelemetry",
    "tracing",
    "monitoring",
    "express",
    "fastify"
  ],
  "license": "MIT",
  "author": "rukkiecodes",
  "homepage": "https://rukkiepulse.netlify.app",
  "repository": {
    "type": "git",
    "url": "https://github.com/rukkiecodes/rukkiepulse.git",
    "directory": "agents/node"
  },
  "bugs": {
    "url": "https://github.com/rukkiecodes/rukkiepulse/issues"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-trace-otlp-grpc": "^0.57.0",
    "@opentelemetry/instrumentation-express": "^0.44.0",
    "@opentelemetry/instrumentation-fastify": "^0.44.0",
    "@opentelemetry/instrumentation-http": "^0.57.0",
    "@opentelemetry/resources": "^1.29.0",
    "@opentelemetry/sdk-node": "^0.57.0",
    "@opentelemetry/sdk-trace-node": "^1.29.0",
    "@opentelemetry/semantic-conventions": "^1.28.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  },
  "peerDependencies": {
    "express": ">=4.0.0",
    "fastify": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "express": { "optional": true },
    "fastify": { "optional": true }
  },
  "engines": {
    "node": ">=18.0.0"
  }
